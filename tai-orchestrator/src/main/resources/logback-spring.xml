<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <timestamp key="startupTimestamp" datePattern="yyyyMMdd-HHmmss"/>

    <property name="LOG_DIR" value="tai-orchestrator/logs"/>
    <property name="CONVERSATION_LOG_FILE" value="${LOG_DIR}/${startupTimestamp}-conversation.log"/>
    <springProperty name="TAI_CONVERSATION_LEVEL" source="logging.level.tai.conversation" defaultValue="INFO"/>
    <springProperty name="ROOT_LEVEL" source="logging.level.root" defaultValue="INFO"/>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <appender name="CONVERSATION_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${CONVERSATION_LOG_FILE}</file>
        <append>false</append>
        <encoder>
            <pattern>%msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Default console logging -->
    <root level="%{ROOT_LEVEL}">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Conversation logs only go to dedicated file, not console -->
    <logger name="tai.conversation" level="%{TAI_CONVERSATION_LEVEL}" additivity="false">
        <appender-ref ref="CONVERSATION_FILE"/>
    </logger>

</configuration>
