# Orchestrator base URL used for /ui/state, /ui/events, /ui/modules, /ui/history and /ui/manual-input.
# In dev, use the Vite proxy to avoid browser CORS issues.
VITE_TAI_ORCHESTRATOR_BASE_URL=/tai-api

# Target used by the Vite dev proxy. Change this if the orchestrator does not run on localhost:8080.
VITE_TAI_ORCHESTRATOR_TARGET=http://localhost:8080

# Stop Speak is intentionally optional because the orchestrator endpoint is planned but not exposed yet.
# When the endpoint exists, set the relative path here, for example: /ui/stop-speak
VITE_TAI_STOP_SPEAK_PATH=

# Optional: enable a small diagnostics overlay in the avatar panel by default.
VITE_TAI_AVATAR_DIAGNOSTICS=false
